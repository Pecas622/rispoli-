{
      "routes": [
              { "src": "/sitemap.xml", "dest": "/api/sitemap" },
              { "handle": "filesystem" },
              { "src": "^/$", "dest": "/index.html" },
              { "src": "^/(cursos(/[^/]+)?|dashboard|admin(/courses/[^/]+/content)?|instructor|reset-password|certificaciones|descargas|perfil|empresas|nosotros|blog|contacto)/?$", "dest": "/index.html" },
              { "src": "/(.*)", "status": 404, "dest": "/index.html" }
      ]
}
