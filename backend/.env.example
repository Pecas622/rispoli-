# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (Supabase → Settings → Database → Connection string) ──
DATABASE_URL="postgresql://postgres:[TU_PASSWORD]@[TU_HOST]:5432/postgres?schema=public"

# ── JWT ───────────────────────────────────────────────────
# Generá una clave segura: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia-esto-por-una-clave-segura-de-al-menos-64-caracteres"
JWT_EXPIRES_IN="7d"

# ── Stripe ────────────────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
# Dashboard → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."
# Moneda: "ars" para pesos argentinos, "usd" para dólares
STRIPE_CURRENCY="ars"

# ── Resend (emails) ───────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY="re_..."
# El dominio debe estar verificado en Resend
RESEND_FROM="GO Travel Academy <noreply@gotravelacademy.com>"

# ── Frontend URL (CORS + redirects Stripe) ────────────────
FRONTEND_URL="http://localhost:5173"
