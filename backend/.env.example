# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database (Supabase → Settings → Database → Connection string) ──────────────
DATABASE_URL="postgresql://postgres:[TU_PASSWORD]@[TU_HOST]:5432/postgres?schema=public"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generá una clave segura:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia-esto-por-una-clave-segura-de-al-menos-64-caracteres"
JWT_EXPIRES_IN="7d"

# ── Stripe (pagos internacionales — USD) ──────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY="sk_test_..."
# Dashboard → Developers → Webhooks → tu endpoint → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Mercado Pago (pagos Argentina — ARS) ──────────────────────────────────────
# Dashboard MP → Tus integraciones → Credenciales
# https://www.mercadopago.com.ar/settings/account/credentials
MP_ACCESS_TOKEN="APP_USR-..."
# Secret para validar la firma de los webhooks IPN
# Configurar en: https://www.mercadopago.com.ar/developers/es/docs/your-integrations/notifications/webhooks
MP_WEBHOOK_SECRET="tu-webhook-secret-mp"
# URL pública del backend para que MP pueda enviar notificaciones (usar ngrok en dev)
BACKEND_URL="https://tu-backend.railway.app"

# ── Brevo (emails transaccionales) ────────────────────────────────────────────
# app.brevo.com → SMTP & API → API Keys
BREVO_API_KEY="xkeysib-..."
# Debe ser un email verificado en Brevo (Senders, Domains & Dedicated IPs → Senders)
BREVO_FROM_EMAIL="noreply@gotravelacademy.com"
BREVO_FROM_NAME="GO Travel Academy"

# ── Frontend URL (CORS + redirects post-pago) ─────────────────────────────────
FRONTEND_URL="http://localhost:5173"

# ── Meta Conversions API (CAPI — medición server-side) ────────────────────────
# Mismo Pixel ID que el frontend (VITE_META_PIXEL_ID). Es público.
META_PIXEL_ID="1725484131770213"
# Token de acceso de la CAPI (SECRETO). Events Manager → tu Pixel → Configuración
# → API de Conversiones → Generar token de acceso. NUNCA subir al repo.
META_CAPI_TOKEN="EAAG..."
# Opcional: solo para la pestaña "Probar eventos" de Meta. Dejar vacío en producción.
META_TEST_EVENT_CODE=""

# ── Google Sign-In (Google Cloud Console → APIs & Services → Credentials) ─────
# Mismo Client ID que VITE_GOOGLE_CLIENT_ID del frontend (se usa para verificar
# el token, no hace falta client secret con este flujo)
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
